# ⚠️  SECURITY NOTICE ⚠️
# This is a TEMPLATE file. DO NOT store real credentials here.
# Copy this to .env and fill with actual values locally.
# .env is in .gitignore and should NEVER be committed to git.
#
# If credentials are ever exposed in git history:
# 1. Immediately revoke the compromised credentials
# 2. Generate new ones
# 3. Use git-filter-branch or BFG to remove from history
# 4. Force push (only if safe to do so)

# Groq API Key (Free - https://console.groq.com/keys)
# Get your free API key from: https://console.groq.com/keys
# No credit card required, no quota limits
GROQ_API_KEY=your_actual_groq_api_key_here

# Neon PostgreSQL Database URL
# Format: postgresql://username:password@host/database?params
# Get from: https://console.neon.tech
# Required for resume storage features
DATABASE_URL=postgresql://your_username:your_password@your_host/your_database?sslmode=require

# Optional: Google Drive API Credentials
# Only needed if using Google Drive storage
# Get from: https://console.cloud.google.com
# GOOGLE_CREDENTIALS_FILE=credentials.json

# Optional: Dropbox API Token
# Only needed if using Dropbox storage
# Get from: https://www.dropbox.com/developers/apps
# DROPBOX_ACCESS_TOKEN=your_dropbox_token_here
